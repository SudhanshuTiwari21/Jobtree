# Server Configuration
NODE_ENV=development
PORT=3000

# Twilio (OTP SMS + masked calls) — E.164 numbers, e.g. +14155551234
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Voice caller ID for masked calls; also used for SMS unless TWILIO_SMS_FROM is set
TWILIO_PHONE_NUMBER=+10000000000
# Optional: different Twilio number for SMS only (defaults to TWILIO_PHONE_NUMBER)
# TWILIO_SMS_FROM=+10000000000
# Public base URL for Twilio webhooks (voice), e.g. https://api.example.com
# BASE_URL=https://api.example.com

# OTP Configuration
OTP_LENGTH=5
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Security
JWT_SECRET=your_jwt_secret_key_here_change_in_production
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
